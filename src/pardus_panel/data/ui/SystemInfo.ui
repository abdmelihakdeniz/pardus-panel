<?xml version="1.0" encoding="UTF-8"?>
<interface domain="pardus-panel">
  <requires lib="gtk+" version="3.20"/>
  <object class="GtkSizeGroup">
    <property name="mode">horizontal</property>
    <widgets>
      <widget name="system_info_os_list"/>
      <widget name="system_info_hostname_list"/>
      <widget name="system_info_list"/>
    </widgets>
  </object>
  <object class="GtkBox" id="system_info_content">
    <property name="orientation">vertical</property>
    <property name="spacing">14</property>
    <property name="margin">16</property>
    <style><class name="page-content"/><class name="system-info-page"/></style>
    <child>
      <object class="GtkBox">
        <property name="orientation">vertical</property>
        <property name="spacing">4</property>
        <property name="halign">center</property>
        <style><class name="page-header"/></style>
        <child>
          <object class="GtkImage" id="system_info_icon">
            <property name="icon-name">preferences-system-symbolic</property>
            <property name="pixel-size">48</property>
            <property name="halign">center</property>
          </object>
        </child>
        <child>
          <object class="GtkBox">
            <property name="orientation">vertical</property>
            <property name="spacing">4</property>
            <child><object class="GtkLabel"><property name="label" translatable="yes">System Information</property><property name="xalign">0.5</property><style><class name="page-title"/></style></object></child>
            <child><object class="GtkLabel"><property name="label" translatable="yes">View operating system and hardware details.</property><property name="xalign">0.5</property><property name="wrap">True</property><property name="justify">center</property><style><class name="page-description"/></style></object></child>
          </object>
        </child>
      </object>
    </child>
    <child>
      <object class="GtkBox">
        <property name="orientation">vertical</property>
        <property name="spacing">10</property>
        <property name="halign">center</property>
        <property name="width-request">560</property>
        <child>
          <object class="GtkListBox" id="system_info_os_list">
            <property name="selection-mode">none</property>
            <style><class name="system-info-list"/></style>
            <child>
              <object class="GtkListBoxRow">
                <property name="selectable">False</property>
                <property name="activatable">False</property>
                <child><object class="GtkBox"><property name="orientation">vertical</property><property name="spacing">2</property><style><class name="system-info-row"/></style><child><object class="GtkLabel"><property name="label" translatable="yes">Operating system</property><property name="xalign">0</property><style><class name="dim-label"/></style></object></child><child><object class="GtkLabel" id="system_info_os"><property name="xalign">0</property><property name="selectable">True</property><property name="ellipsize">end</property><style><class name="system-info-value"/></style></object></child></object></child>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkListBox" id="system_info_hostname_list">
            <property name="selection-mode">none</property>
            <style><class name="system-info-list"/></style>
            <child>
              <object class="GtkListBoxRow">
                <property name="selectable">False</property>
                <property name="activatable">False</property>
                <child><object class="GtkBox"><property name="orientation">vertical</property><property name="spacing">2</property><style><class name="system-info-row"/></style><child><object class="GtkLabel"><property name="label" translatable="yes">Hostname</property><property name="xalign">0</property><style><class name="dim-label"/></style></object></child><child><object class="GtkLabel" id="system_info_hostname"><property name="xalign">0</property><property name="selectable">True</property><property name="ellipsize">end</property><style><class name="system-info-value"/></style></object></child></object></child>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
    <child>
      <object class="GtkScrolledWindow">
        <property name="hscrollbar-policy">never</property>
        <property name="vscrollbar-policy">automatic</property>
        <property name="propagate-natural-height">True</property>
        <property name="shadow-type">none</property>
        <child>
          <object class="GtkListBox" id="system_info_list">
            <property name="selection-mode">none</property>
            <property name="activate-on-single-click">False</property>
            <property name="halign">center</property>
            <property name="width-request">560</property>
            <property name="margin">2</property>
            <style><class name="system-info-list"/></style>
            <child>
              <object class="GtkListBoxRow">
                <property name="selectable">False</property>
                <property name="activatable">False</property>
                <child><object class="GtkBox"><property name="orientation">vertical</property><property name="spacing">2</property><style><class name="system-info-row"/></style><child><object class="GtkLabel"><property name="label" translatable="yes">Kernel</property><property name="xalign">0</property><style><class name="dim-label"/></style></object></child><child><object class="GtkLabel" id="system_info_kernel"><property name="xalign">0</property><property name="selectable">True</property><property name="ellipsize">end</property><style><class name="system-info-value"/></style></object></child></object></child>
              </object>
            </child>
            <child>
              <object class="GtkListBoxRow">
                <property name="selectable">False</property>
                <property name="activatable">False</property>
                <child><object class="GtkBox"><property name="orientation">vertical</property><property name="spacing">2</property><style><class name="system-info-row"/></style><child><object class="GtkLabel"><property name="label" translatable="yes">Processor</property><property name="xalign">0</property><style><class name="dim-label"/></style></object></child><child><object class="GtkLabel" id="system_info_cpu"><property name="xalign">0</property><property name="selectable">True</property><property name="ellipsize">end</property><style><class name="system-info-value"/></style></object></child></object></child>
              </object>
            </child>
            <child>
              <object class="GtkListBoxRow">
                <property name="selectable">False</property>
                <property name="activatable">False</property>
                <child><object class="GtkBox"><property name="orientation">vertical</property><property name="spacing">2</property><style><class name="system-info-row"/></style><child><object class="GtkLabel"><property name="label" translatable="yes">Graphics</property><property name="xalign">0</property><style><class name="dim-label"/></style></object></child><child><object class="GtkLabel" id="system_info_gpu"><property name="xalign">0</property><property name="selectable">True</property><property name="ellipsize">end</property><style><class name="system-info-value"/></style></object></child></object></child>
              </object>
            </child>
            <child>
              <object class="GtkListBoxRow">
                <property name="selectable">False</property>
                <property name="activatable">False</property>
                <child><object class="GtkBox"><property name="orientation">vertical</property><property name="spacing">2</property><style><class name="system-info-row"/></style><child><object class="GtkLabel"><property name="label" translatable="yes">Memory</property><property name="xalign">0</property><style><class name="dim-label"/></style></object></child><child><object class="GtkLabel" id="system_info_memory"><property name="xalign">0</property><style><class name="system-info-value"/></style></object></child></object></child>
              </object>
            </child>
            <child>
              <object class="GtkListBoxRow">
                <property name="selectable">False</property>
                <property name="activatable">False</property>
                <child><object class="GtkBox"><property name="orientation">vertical</property><property name="spacing">2</property><style><class name="system-info-row"/></style><child><object class="GtkLabel"><property name="label" translatable="yes">System disk</property><property name="xalign">0</property><style><class name="dim-label"/></style></object></child><child><object class="GtkLabel" id="system_info_disk"><property name="xalign">0</property><style><class name="system-info-value"/></style></object></child></object></child>
              </object>
            </child>
          </object>
        </child>
      </object>
      <packing><property name="fill">True</property></packing>
    </child>
    <child><object class="GtkLabel" id="system_info_status"><property name="xalign">0</property><property name="wrap">True</property><style><class name="muted-label"/></style></object></child>
  </object>
</interface>
